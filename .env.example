# =========================================================
# HubEvent - Variáveis de ambiente (MODELO)
# Copie este arquivo para ".env" e preencha com valores reais.
# NUNCA versione o arquivo ".env" com credenciais reais.
# =========================================================

# --- Flask ---
FLASK_SECRET_KEY=troque-esta-chave-em-producao
FLASK_DEBUG=True

# --- Credenciais AWS ---
# Podem ser credenciais de um usuário IAM ou de uma sessão temporária
# (AWS Academy / AWS Educate costumam gerar Access Key + Secret + Session Token).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# --- Amazon S3 ---
AWS_BUCKET_NAME=ticketbio-bernardo

# --- Amazon Rekognition ---
AWS_REKOGNITION_COLLECTION=ticketbio-faces
REKOGNITION_SIMILARITY_THRESHOLD=95

# --- Amazon DynamoDB ---
DYNAMODB_TABLE_USERS=Usuarios
DYNAMODB_TABLE_EVENTS=Eventos
DYNAMODB_TABLE_TICKETS=Ingressos

# --- AWS Lambda ---
AWS_LAMBDA_CONFIRMA_COMPRA=hubevent-confirma-compra
